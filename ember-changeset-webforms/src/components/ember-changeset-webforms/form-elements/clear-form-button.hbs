<button
  type="button"
  data-test-id="cwf-clear-form-button"
  {{on "click" (fn @clearForm @changesetWebform)}}
  {{attrs-from-config "buttonElement,clearFormButton" @changesetWebform}}
>
  {{#if @formSettings.clearFormButtonIcon}}
    <@formSettings.clearFormButtonIcon.componentClass
      @props={{@formSettings.clearFormButtonIcon.props}}
      @changesetWebform={{@changesetWebform}}
      {{attrs-from-config "buttonIcon,clearFormButtonIcon" @changesetWebform}}
    />
  {{/if}}
  {{@formSettings.clearFormButtonText}}</button>