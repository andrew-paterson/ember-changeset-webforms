<PowerSelect
  @searchField={{@formField.optionDisplayProp}}
  @allowClear={{false}}
  @searchEnabled={{true}}
  @closeOnSelect={{false}}
  @searchPlaceholder={{@formField.searchPlaceholder}}
  @options={{@formField.options}}
  @selected={{@formField.fieldValue}}
  @placeholder={{@formField.placeholder}}
  @onChange={{this.optionToggled}}
  @onKeydown={{this.onkeydown}}
  @onClose={{this.onclose}}
  @onOpen={{this.onOpen}}
  @extra={{hash fieldValue=@formField.fieldValue}}
  @triggerComponent={{@formField.triggerComponent}}
  @triggerId={{@fieldId}}
  @ariaDescribedBy={{@formField.ariaDescribedBy}}
  @ariaInvalid={{@formField.ariaInvalid}}
  @ariaLabel={{@formField.ariaLabel}}
  @ariaLabelledBy={{@formField.ariaLabelledBy}}
  @required={{@formField.required}}
  aria-errormessage={{@formField.ariaErrorMessage}}
  @loadingMessage={{@formField.loadingMessage}}
  {{attrs-from-config
    "powerSelectCheckboxesTrigger"
    @changesetWebform
    @formField
  }}
  as |option|
>
  <Background::PowerSelectOptionCheckbox
    @option={{option}}
    @options={{@formField.options}}
    @selected={{@formField.fieldValue}}
    @optionDisplayProp={{@formField.optionDisplayProp}}
    @fieldId={{@formField.fieldId}}
    @changesetWebform={{@changesetWebform}}
    @optionName={{if
      @formField.optionDisplayProp
      (get option @formField.optionDisplayProp)
      option
    }}
  />
</PowerSelect>