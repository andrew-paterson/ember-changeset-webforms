<div
  {{attrs-from-config "optionsWrapper" @changesetWebform @formField}}
  aria-label={{@formField.ariaLabel}}
  data-test-id="options-wrapper"
  ...attributes
>
  {{#each @formField.options as |option|}}
    <Background::LabelledRadioButton
      @value={{option.value}}
      @groupValue={{@formField.fieldValue}}
      @name={{or @formField.name @formField.id}}
      @disabled={{if @formField.disabled true option.disabled}}
      @label={{option.label}}
      @optionLabelComponent={{or
        option.optionLabelComponent
        @formField.optionLabelComponent
      }}
      @optionLabelMarkdown={{option.optionLabelMarkdown}}
      @containerName={{@formSettings.formName}}
      @changedAction={{this.onRadioChange}}
      @option={{option}}
      @changesetWebform={{@changesetWebform}}
      @required={{@formField.required}}
      @formField={{@formField}}
    />
  {{/each}}
</div>