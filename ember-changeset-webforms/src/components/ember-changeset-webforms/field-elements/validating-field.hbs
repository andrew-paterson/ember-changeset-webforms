{{#if
  (and
    @changesetWebform.changeset
    (not @formField.isOmitted)
    (not-eq @formField.fieldType "noDisplay")
  )
}}
  {{#if @formField.cloneGroupName}}
    <EmberChangesetWebforms::ClonedFieldElements::ValidatingCloneGroup
      @masterFormField={{@formField}}
      @updateFieldValue={{this.updateFieldValue}}
      @validateField={{this.validateField}}
      @afterClickAddCloneButton={{@afterClickAddCloneButton}}
      @onUserInteraction={{this.onUserInteraction}}
      @dataTestFieldId={{or @dataTestId @formField.id}}
      @changesetWebform={{@changesetWebform}}
      {{did-insert this.didInsert}}
      {{will-destroy this.willDestroyAction}}
    />
  {{else}}
    <EmberChangesetWebforms::FieldElements::ValidatingFieldWrapper
      @formField={{@formField}}
      @typeClass={{@formField.typeClass}}
      @dataTestFormName={{@dataTestFormName}}
      @dataTestFieldId={{or @dataTestId @formField.id}}
      @changesetWebform={{@changesetWebform}}
      @labelId={{@formField.labelId}}
      @ariaLabelledBy={{@formField.ariaLabelledBy}}
      @ariaLabel={{@formField.ariaLabel}}
      @validationErrorsArray={{@formField.validationErrors}}
      data-test-cwf-field
      {{did-insert this.didInsert}}
      {{will-destroy this.willDestroyAction}}
    >
      <@formField.componentClass
        @formField={{@formField}}
        @formFields={{@formFields}}
        @formSettings={{@formSettings}}
        @updateFieldValue={{this.updateFieldValue}}
        @onUserInteraction={{this.onUserInteraction}}
        @changesetWebform={{@changesetWebform}}
        @dataTestFieldId={{or @dataTestId @formField.id}}
        @labelId={{@formField.labelId}}
        @ariaLabelledBy={{@formField.ariaLabelledBy}}
        @ariaErrorMessage={{@formField.ariaErrorMessage}}
        @ariaDescribedBy={{@formField.ariaDescribedBy}}
        @onFormSubmit={{@onFormSubmit}}
      />
      {{#if @formField.description}}
        <EmberChangesetWebforms::FieldElements::FieldDescription
          @description={{@formField.description}}
          @descriptionMarkdown={{@formField.descriptionMarkdown}}
        />
      {{/if}}
    </EmberChangesetWebforms::FieldElements::ValidatingFieldWrapper>
  {{/if}}
{{/if}}