<EmberChangesetWebforms::FieldElements::ValidatingFieldWrapperElement
  @formField={{@formField}}
  data-test-cwf-field-wrapper={{not @formField.isClone}}
  data-test-cwf-clone-wrapper={{@formField.isClone}}
  data-test-class={{this.dataTestClass}}
  data-test-cwf-field-validates={{this.formField.validates}}
  data-test-cwf-field-required={{this.formField.required}}
  data-test-id={{@dataTestFieldId}}
  data-test-validates={{@formField.validates}}
  data-test-was-validated={{@formField.wasValidated}}
  data-test-validation-status={{@formField.validationStatus}}
  class="{{@typeClass}}
    {{if
      @formField.isClone
      (ember-changeset-webforms/dynamic-class-names
        'cloneWrapper' @changesetWebform @formField
      )
      (ember-changeset-webforms/dynamic-class-names
        'fieldWrapper' @changesetWebform @formField
      )
    }}
    {{if
      (and @formField.isClone this.hasFieldActions)
      (ember-changeset-webforms/dynamic-class-names
        'cloneWrapperWithRemoveButton' @changesetWebform @formField
      )
    }}
    {{if
      @formField.focussed
      (ember-changeset-webforms/dynamic-class-names
        'focussedField' @changesetWebform @formField
      )
    }}
    {{if
      @formField.disabled
      (ember-changeset-webforms/dynamic-class-names
        'disabledField' @changesetWebform @formField
      )
    }}
    {{if
      @formField.validates
      (ember-changeset-webforms/dynamic-class-names
        'fieldValidates' @changesetWebform @formField
      )
    }}
    {{if
      @formField.wasValidated
      (ember-changeset-webforms/dynamic-class-names
        'validatedField' @changesetWebform @formField
      )
    }}
    {{if
      @formField.required
      (ember-changeset-webforms/dynamic-class-names
        'requiredField' @changesetWebform @formField
      )
    }}
    {{if @formField.readonly 'readonly'}}
    {{if @formField.hideSuccessValidation 'hide-success-validation'}}"
  {{did-insert (fn this.registerElementContainer "fieldWrapperEl")}}
  ...attributes
>
  {{#if this.hasFieldActions}}
    <div
      data-field-actions
      {{did-insert (fn this.registerElementContainer "fieldActions")}}
    ></div>
  {{/if}}
  {{#if @formField.isClone}}
    <div
      data-field-content
      {{did-insert (fn this.registerElementContainer "fieldContents")}}
    ></div>
  {{/if}}
  {{#if this.fieldContentsDestinationElement}}
    {{#in-element this.fieldContentsDestinationElement insertBefore=null}}
      <EmberChangesetWebforms::FieldElements::FieldLabel
        @formField={{@formField}}
        @changesetWebform={{@changesetWebform}}
        @labelId={{@labelId}}
      />
      <EmberChangesetWebforms::FieldElements::FieldDescription
        @formField={{@formField}}
        @changesetWebform={{@changesetWebform}}
      />
      <div
        class="{{if
            @formField.isClone
            (ember-changeset-webforms/dynamic-class-names
              'cloneFieldControls' @changesetWebform @formField
            )
            (ember-changeset-webforms/dynamic-class-names
              'fieldControls' @changesetWebform @formField
            )
          }}"
        role={{if @formField.isGroup "group"}}
        data-test-id="field-controls"
      >
        {{yield}}
      </div>

      <EmberChangesetWebforms::FieldElements::FieldErrors
        @formField={{@formField}}
        @changesetWebform={{@changesetWebform}}
        @validationErrorsArray={{@validationErrorsArray}}
      />
    {{/in-element}}
  {{/if}}
  {{#if this.cloneActionsDestinationElement}}
    {{#in-element this.cloneActionsDestinationElement insertBefore=null}}
      <EmberChangesetWebforms::ClonedFieldElements::RemoveCloneButton
        @formField={{@formField}}
        @masterFormField={{@masterFormField}}
        @removeClone={{@removeClone}}
        @changesetWebform={{@changesetWebform}}
      />
    {{/in-element}}
  {{/if}}
</EmberChangesetWebforms::FieldElements::ValidatingFieldWrapperElement>