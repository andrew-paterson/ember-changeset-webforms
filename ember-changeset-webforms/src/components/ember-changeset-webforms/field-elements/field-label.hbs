{{#unless this.noLabel}}
  <EmberChangesetWebforms::FieldElements::FieldLabelWrapper
    id={{@labelId}}
    {{attrs-from-config "fieldLabel" @changesetWebform @formField}}
    data-test-class="cwf-field-label"
    data-test-id="{{@formField.id}}-label"
    @formField={{@formField}}
    @changesetWebform={{@changesetWebform}}
  >
    {{#if @formField.labelComponent}}
      <@formField.labelComponent.componentClass
        @props={{@formField.labelComponent.componentClass}}
        @changesetWebform={{@changesetWebform}}
        @formField={{@formField}}
      />
    {{else if @formField.labelMarkdown}}
      <Background::MarkdownToHtml @source={{@formField.labelMarkdown}} />
    {{else if @formField.fieldLabel}}
      {{@formField.fieldLabel}}

    {{/if}}
  </EmberChangesetWebforms::FieldElements::FieldLabelWrapper>
{{/unless}}